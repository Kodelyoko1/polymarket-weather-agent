# PolyMarket Credentials (get from polymarket.com -> Profile -> API)
# IMPORTANT: Never commit real credentials. Use environment variables in Render.
PW_PRIVATE_KEY=
PW_API_KEY=
PW_API_SECRET=

# Trading Configuration
PW_LIVE_TRADING=0          # Set to 1 ONLY when ready to trade real money
PW_BANKROLL=1000           # Starting capital in USDC
PW_MIN_EDGE=0.07           # Minimum probability edge (7%)
PW_MIN_LIQUIDITY=500       # Minimum market liquidity in USDC
PW_KELLY_FRACTION=0.25     # Fractional Kelly multiplier (conservative)
PW_MAX_POSITION_PCT=0.05   # Max position size (5% of bankroll)
PW_CYCLE_MINUTES=60        # Minutes between trading cycles
PW_DATA_REFRESH_HOURS=6    # Hours before refreshing data
PW_RETRAIN_DAYS=7          # Days before retraining models

# Optional: Email Digests
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PW_OWNER_EMAIL=

# Optional: Render Free Tier Keep-Alive
AGENT_PASSWORD=owner
